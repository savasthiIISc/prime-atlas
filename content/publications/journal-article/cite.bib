@article{chouhan_large_2017,
	title = {Large grained and high charge carrier lifetime {CH}$_3${NH}$_3${PbI}$_3$ thin-films: {Implications} for perovskite solar cells},
	volume = {17},
	issn = {1567-1739},
	url = {http://www.sciencedirect.com/science/article/pii/S1567173917301979},
	doi = {10.1016/j.cap.2017.07.005},
	number = {10},
	journal = {Current Applied Physics},
	author = {Chouhan, Arun Singh and Jasti, Naga Prathibha and Hadke, Shreyash and Raghavan, Srinivasan and Avasthi, Sushobhan},
	year = {2017},
	month = oct,
	keywords = {Large grains, Methylamine vapor annealing, Microwave detected carrier lifetime, morphology, perovskite, solar cell},
	pages = {1335 -- 1340},
	abstract = {Spin coated perovskite thin films are known to have an issue of pinholes \& poor morphology control which lead to poor device-to-device repeatability, that is an impediment to scale-up. In this work, Methylamine vapor annealing process is demonstrated which consistently leads to high-quality perovskite thin-films with an average grain-size of 10–15 \micro m. The improvement in film morphology enables improvement in effective carrier recombination lifetime, from 21 \micro s in as-deposited films to 54 \micro s in vapor-annealed films. The annealed films with large-grains are also more stable in ambient conditions. Devices made on annealed perovskite films are very consistent, with a standard deviation of only 0.7\%. Methylamine vapor annealing process is a promising method of depositing large-grain CH$_3$NH$_3$PbI$_3$ films with high recombination lifetime and the devices with improved performance.}
}

@article{chaurasia_wafer-scale_2018,
	title = {Wafer-scale epitaxial germanium (100), (111), (110) films on silicon using liquid phase crystallization},
	volume = {8},
	url = {https://doi.org/10.1063/1.5033324},
	doi = {10.1063/1.5033324},
	number = {7},
	journal = {AIP Advances},
	author = {Chaurasia, Saloni and Mohan, Nagaboopathy and Raghavan, Srinivasan and Avasthi, Sushobhan},
	year = {2018},
	month = jul,
	pages = {075010},
	abstract = {A wafer-scale method to obtain epitaxial germanium (Ge) on crystalline silicon ({Si}) using liquid-phase-crystallization (LPC) is presented. The technique provides a simple yet versatile method to grow epitaxial germanium on silicon with any crystallographic orientation: (100), (110) or (111). The process starts with amorphous Ge, which is melted and cooled in a controlled manner to form epitaxial germanium. LPC Ge films are continuous with an average grain-size of 2-5 \micro m. Rocking scan confirms that the LPC Ge is oriented with a threading dislocation density of <10$^9$ cm$^-2$. The phi-scan confirms that LPC germanium is epitaxial with Ge (100), Ge (110) and Ge (111) showing four-fold, two-fold, and three-fold symmetry, respectively. The epitaxial quality of the Ge is influenced by the cleanliness of the Ge/{Si} interface; rate of cooling and ambient gas during LPC; and Ge layer thickness. Best films are obtained for 1 \micro m thick LPC Ge(100), cooled at ~3-4 C/min in hydrogen ambient. Electron Hall mobility in these LPC Ge films is 736 cm$^2$/Vs, a high value that confirms the electronic quality of LPC Ge film.}	
}

@article{chouhan_effect_2018,
	title = {Effect of interface defect density on performance of perovskite solar cell: {Correlation} of simulation and experiment},
	volume = {221},
	issn = {0167-577X},
	url = {http://www.sciencedirect.com/science/article/pii/S0167577X18304592},
	doi = {10.1016/j.matlet.2018.03.095},
	abstract = {Experimental data from a 17.5\% efficient perovskite solar cell has been used to develop a self-consistent device model using Solar Cell Capacitance Simulator (SCAPS). Electronic properties of the individual layers, such as doping density of compact TiO2 (c-TiO2), doping and defect density of perovskite, etc. are extracted from experimental data. The only fitting parameters in the model are the defect densities at spiro-MeOTAD/perovskite interface (IL-1) and perovskite/TiO2 interface (IL-2). The simulated current-voltage (J-V) characteristics and Mott-Schottky plot results match extremely well with the experimentally measured plots, validating the device model. The model was further used to extract insights into the loss mechanism of the high-efficiency perovskite solar cells. Simulations revealed that defect density at IL-1 interface has strong impact on the open-circuit voltage (Voc), while defect density in the perovskite and IL2 interface has a major impact on short-circuit current density (Jsc).},
	journal = {Materials Letters},
	author = {Chouhan, Arun Singh and Jasti, Naga Prathibha and Avasthi, Sushobhan},
	year = {2018},
	month = jun,
	keywords = {Device fabrication, Interface defects, SCAPS},
	pages = {150 -- 153}
}

@article{biswas_optical_2017,
	title = {Optical Properties of {Zn$_2$Mo$_3$O$_8$}: {Combination} of Theoretical and Experimental Study},
	volume = {121},
	issn = {1932-7447},
	url = {https://doi.org/10.1021/acs.jpcc.7b07473},
	doi = {10.1021/acs.jpcc.7b07473},
