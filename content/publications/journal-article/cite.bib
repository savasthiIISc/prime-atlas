@article{ravindra_hole-selective_2017,
	title = {Hole-Selective Electron-Blocking Copper Oxide Contact for Silicon Solar Cells},
	volume = {7},
	issn = {2156-3381},
	doi = {10.1109/JPHOTOV.2017.2720619},
	abstract = {Metal-oxide/silicon carrier-selective heterojunctions 5 be a low-cost high-efficiency alternative to conventional silicon solar cells. Here, a passivated {Si}/cuprous oxide ({Cu$_2$O}) hole-selective heterojunction with high open-circuit voltage ({V$_{OC}$}) is reported. Cu$_2$O is abundant, nontoxic, and can be deposited at low temperatures and potentially at low cost. The {Si}/{Cu$_2$O} heterojunction has a large conduction band offset of 0.9 eV and a negligible valence band offset, which blocks the transport of electrons but allows the transport of holes. The as-deposited hetero-interface is limited due to a high density of defects. However, the interface defect density can be reduced by a 1.2 nm thin tunneling SiO2 layer, which enables the realization of a {Si}/Cu$_2$O heterojunction solar cell with an open-circuit voltage (VOC) of 0.528 V, a 200 mV improvement over the state-of-the-art.},
	number = {5},
	journal = {{IEEE} Journal of Photovoltaics},
	author = {Ravindra, P. and Mukherjee, R. and Avasthi, S.},
	month = sep,
	year = {2017},
	keywords = {Absorption, Charge carrier processes, conduction band offset, conduction bands, copper compounds, elemental semiconductors, heterointerface, Heterojunctions, heterojunction solar cell, Hole-selective contact, hole-selective electron-blocking copper oxide contact, Impurities, interface defect density, open-circuit voltage, passivated Si/cuprous oxide hole-selective heterojunction, passivation, Photovoltaic cells, semiconductor heterojunctions, semiconductor interfaces, Si-Cu$_2$O, silicon, silicon compounds, SILICON SOLAR CELLS, SiO2, size 1.2 nm, Solar cells, Solar Energy, Spectroscopy, thin tunneling layer, tunnelling, voltage 0.528 V, selected},
	pages = {1278--1283}
}

