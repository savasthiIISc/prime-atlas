@inproceedings{kumari_grain_2017, 
	author={Khushboo Kumari and Sushobhan Avasthi}, 
	booktitle={2017 {IEEE} 44th Photovoltaic Specialist Conference ({PVSC})}, 
	title={Grain boundaries in Thin-Film Polycrystalline {GaAs} Solar Cells: {A} Simulation Study}, 
	year={2017},  
	pages={251-254}, 
	abstract={There is a demand of highly efficient, thin, light and flexible solar cells. Polycrystalline {GaAs} could satisfy this need. However, effect of grain size on performance has to be evaluated. Here, the effect of grain boundaries under dark and illuminated conditions is quantified. A 2-D simulation of single junction {GaAs} solar cell was done using SILVACO software. Columnar grain structures were assumed for simplicity and also because these kinds of grain structures give maximum efficiency. Device performance was simulated for various grain sizes, assuming Gaussian distribution and varying density of defect states at the grain boundary. Carrier lifetime of at least 10 ns was required to have proposed efficiency of greater than 20\% for a grain size lesser than 100 \micro m.}, 
	keywords={carrier lifetime;defect states;gallium arsenide;Gaussian distribution;grain boundaries;grain size;III-V semiconductors;semiconductor thin films;solar cells;grain boundary;light cells;flexible solar cells;columnar grain structures;grain size;thin-film polycrystalline solar cells;SILVACO software;single junction solar cell;Gaussian distribution;carrier lifetime;defect states;{GaAs};Gallium arsenide;Photovoltaic cells;Grain boundaries;Grain size;Charge carrier lifetime;Performance evaluation;Spontaneous emission;Gallium Arsenide;Grain boundary;Polycrystalline;Solar cell;Simulation}, 
	doi={10.1109/PVSC.2017.8366277}, 
	ISSN={}, 
	month=jun,
	location={Washington D.C., USA}
}

@inproceedings{ravindra_electro_2017, 
	author={Pramod Ravindra and Eashwar Athresh and Rajeev Ranjan and Srinivasan Raghavan and Sushobhan Avasthi}, 
	booktitle={2017 {IEEE} 44th Photovoltaic Specialist Conference ({PVSC})}, 
	title={Electro-optical Properties of {Zn$_2$Mo$_3$O$_8$} Thin-Films: {A} Novel Low-Bandgap Solar Absorber}, 
	year={2017}, 
	volume={}, 
	number={}, 
	pages={2399-2402}, 
	abstract={Metal-oxide semiconductors are attractive as solar absorbers because they are abundant, stable, environmentally-safe, and low-cost. This work reports the electronic and optical properties of {Zn$_2$Mo$_3$O$_8$}(ZMO), a novel oxide-based solar absorber. ZMO has a direct bandgap of 1.9-2.1 eV, so it can efficiently absorb visible photons. As-deposited films are polycrystalline and unintentionally doped n-type with ~10$^{17}$ cm$^{-3}$ carriers. Electron mobility of 0.6 - 0.7 cm$^2$/Vs is comparable to other thin-film absorbers like CdTe. The conduction and valence band edges in ZMO are 4.4 eV and 6.3 eV below vacuum level, respectively. Preliminary devices show photoconductivity with a 1.5x increase in current upon illumination.}, 
	keywords={conduction bands;electron mobility;electro-optical effects;energy gap;photoconductivity;photoluminescence;semiconductor growth;semiconductor thin films;solar absorber-convertors;solar cells;valence bands;visible spectra;zinc compounds;electro-optical properties;metal-oxide semiconductors;electronic properties;direct bandgap;visible photons;As-deposited films;electron mobility;thin-film absorbers;low-bandgap solar absorber;oxide-based solar absorber;conduction band edges;valence band edges;vacuum level;photoconductivity;electron volt energy 4.4 eV;electron volt energy 1.9 eV to 2.1 eV;electron volt energy 6.3 eV;Zn2Mo3O8;CdTe;Photonic band gap;Photovoltaic cells;Absorption;Semiconductor device measurement;Optical films;Spectroscopy;photovoltaic cells;semiconductors;oxides;solar absorbers;thin-films}, 
	doi={10.1109/PVSC.2017.8366545}, 
	ISSN={}, 
	month=jun,
	location={Washington D.C., USA}
}

