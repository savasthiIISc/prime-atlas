@article{nagamatsu_12_2014,
	title = {A 12\% Efficient Silicon/{PEDOT}:{PSS} Heterojunction Solar Cell Fabricated at \textless 100 $^{\circ}${C}},
	volume = {4},
	issn = {2156-3381},
	doi = {10.1109/JPHOTOV.2013.2287758},
	abstract = {Solar cells based on a heterojunction between crystalline silicon and the organic polymer PEDOT:PSS were fabricated at temperatures {\textless};100 °C by spin coating. The {Si}/PEDOT interface blocks electrons in n-type silicon from moving to the anode and functions as a low-temperature alternative to diffused p- n junctions. The device takes advantage of the light absorption and transport properties of silicon and combines it with the simplicity of fabrication afforded by organics. Reverse recovery measurements were used to analyze the electron-blocking effectiveness of the heterojunction. The data show that current in the device is primarily due to holes injected from the anode into the silicon. At AM1.5, {Si}/PEDOT heterojunction solar cells achieve power conversion efficiency of 11.7\%, which is among the highest reported values for this class of devices.},
	number = {1},
	journal = {{IEEE} Journal of Photovoltaics},
	author = {Nagamatsu, K. A. and Avasthi, S. and Jhaveri, J. and Sturm, J. C.},
	month = apr,
	year = {2014},
	keywords = {anode, anodes, crystalline silicon, Current measurement, Dark current, diffused p-n junctions, efficient silicon-PEDOT:PSS heterojunction solar cell, elemental semiconductors, fabrication simplicity, heterojunction, heterojunction electron-blocking effectiveness, Heterojunctions, hybrid photovoltaics, n-type silicon, organic polymer PEDOT:PSS, PEDOT: PSS, Photovoltaic cells, Photovoltaic systems, p-n heterojunctions, polymer blends, power conversion efficiency, reverse recovery measurements, Si, silicon, silicon light absorption, silicon organic, silicon transport properties, Si-PEDOT interface, Solar cells, spin coating},
	pages = {260--264}
}

